{
  "manifest_version": 3,
  "name": "AgentCFO — APE Procurement Gatekeeper",
  "version": "1.4.0",
  "description": "Thin-client checkout interceptor — all intelligence runs on the Python APE backend.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AgentCFO",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "js/spoke_extension.js",
        "js/python-bridge.js",
        "js/hardwall-ui.js",
        "js/content.js"
      ],
      "css": ["css/liquid-glass.css"],
      "run_at": "document_idle"
    }
  ]
}
