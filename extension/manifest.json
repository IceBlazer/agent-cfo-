{
  "manifest_version": 3,
  "name": "AgentCFO — AI Finance Assistant",
  "version": "2.1.0",
  "description": "Before you buy, AgentCFO checks for cheaper options, budget fit, and duplicate tools.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-green.png",
    "48": "icons/icon-green.png",
    "128": "icons/icon-green.png"
  },
  "action": {
    "default_title": "AgentCFO — AI Finance Assistant",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-green.png",
      "48": "icons/icon-green.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "js/apiClient.js",
        "js/storage.js",
        "js/spoke_extension.js",
        "js/injectedOverlay.js",
        "js/contentScript.js"
      ],
      "css": ["css/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["demo.html", "preview.html", "css/*", "js/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
